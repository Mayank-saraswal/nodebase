model WaitNode {
  id               String   @id @default(cuid())
  nodeId           String   @unique
  workflowId       String

  // Resume mode: "duration" | "until" | "webhook"
  waitMode         String   @default("duration")

  // Duration mode fields
  duration         Int      @default(30)
  durationUnit     String   @default("minutes")

  // Until mode fields
  untilDatetime    String   @default("")
  timezone         String   @default("UTC")

  // Webhook mode fields
  timeoutDuration  Int      @default(24)
  timeoutUnit      String   @default("hours")
  continueOnTimeout Boolean @default(true)

  // Output
  variableName     String   @default("wait")

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model MergeNode {
  id           String @id @default(cuid())
  nodeId       String @unique
  workflowId   String

  // How many input branches to wait for (2-10)
  inputCount   Int    @default(2)

  // Merge strategy:
  // "position"   — zip by index position
  // "combine"    — combine all fields from all branches into one object (default)
  // "crossJoin"  — cartesian product of all items
  // "keyMatch"   — inner join by a key field
  // "keyDiff"    — outer difference — items in branch1 NOT in branch2
  mergeMode    String @default("combine")

  // For keyMatch and keyDiff modes:
  // The dot-path field to match on e.g. "orderId" or "email"
  // Supports {{variables}} — resolved at runtime
  matchKey1    String @default("")
  matchKey2    String @default("")

  // For position mode:
  // "shortest" — zip to shortest branch length
  // "longest"  — pad shorter branches with null
  positionFill String @default("shortest")

  // Branch variable name selection
  // branchKey1/branchKey2 — variable names of the first/second branch (e.g. "gmail", "slack")
  // branchKeys — comma-separated list for 3+ branch modes (e.g. "gmail,slack,notion")
  branchKey1   String @default("")
  branchKey2   String @default("")
  branchKeys   String @default("")

  // Wait for ALL branches to complete before merging
  waitForAll   Boolean @default(true)

  // Output variable name
  variableName String @default("merge")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflow     workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model ErrorTriggerNode {
  id           String   @id @default(cuid())
  nodeId       String   @unique
  workflowId   String

  variableName String   @default("errorTrigger")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workflow     workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([workflowId])
}

model RazorpayTrigger {
  id            String   @id @default(cuid())
  nodeId        String   @unique
  workflowId    String

  webhookId     String   @unique @default(uuid())

  // DEPRECATED — plaintext, kept for backward-compat until data migration is complete.
  // TODO: Once all rows have webhookSecretEncrypted set and webhookSecret IS NULL,
  // create a follow-up migration to: DROP COLUMN webhookSecret and set
  // webhookSecretEncrypted NOT NULL.
  webhookSecret          String?  // legacy plaintext (pre-encryption rows)

  // AES-256 encrypted webhook secret. Prefer this over webhookSecret.
  // Populated by new saves and by `npm run migrate:razorpay-secrets`.
  webhookSecretEncrypted String?  // encrypted; null until migrated

  activeEvents  String   @default("[]") @db.Text
  variableName  String   @default("razorpayTrigger")
  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflow      workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([workflowId])
  @@index([webhookId])
}

model WhatsAppTrigger {
  id                String   @id @default(cuid())
  nodeId            String   @unique
  workflowId        String

  webhookId         String   @unique @default(uuid())

  // DEPRECATED — plaintext, kept for backward-compat until data migration is complete.
  // TODO: Once all rows have verifyTokenEncrypted set and verifyToken IS NULL,
  // create a follow-up migration to: DROP COLUMN verifyToken and set
  // verifyTokenEncrypted NOT NULL.
  verifyToken              String?  // legacy plaintext (pre-encryption rows)

  // AES-256 encrypted verify token. Prefer this over verifyToken.
  // Populated by new saves and by `npm run migrate:whatsapp-tokens`.
  verifyTokenEncrypted     String?  // encrypted; null until migrated

  phoneNumberId     String   @default("")
  activeEvents      String   @default("[]") @db.Text
  messageTypes      String   @default("[]") @db.Text
  ignoreOwnMessages Boolean  @default(true)
  variableName      String   @default("whatsappTrigger")
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workflow          workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([nodeId])
  @@index([workflowId])
  @@index([webhookId])
}

