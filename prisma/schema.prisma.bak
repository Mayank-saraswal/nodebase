  UPDATE_NOTE
  DELETE_NOTE

  // ── CONTACTS ─────────────────────────────────────────────
  CREATE_CONTACT
  GET_CONTACT
  UPDATE_CONTACT
  DELETE_CONTACT
  LIST_CONTACTS
  SEARCH_CONTACTS
  MERGE_CONTACT

  // ── COMPANIES ────────────────────────────────────────────
  CREATE_COMPANY
  GET_COMPANY
  UPDATE_COMPANY
  DELETE_COMPANY
  LIST_COMPANIES

  // ── AGENTS ───────────────────────────────────────────────
  LIST_AGENTS
  GET_AGENT
  UPDATE_AGENT

  // ── CONVERSATIONS ────────────────────────────────────────
  LIST_CONVERSATIONS
  SEND_REPLY
  CREATE_OUTBOUND_EMAIL

  // ── GENERIC ──────────────────────────────────────────────
  GET_TICKET_STATS
}

model FreshdeskNode {
  id           String             @id @default(cuid())
  nodeId       String             @unique
  workflowId   String
  credentialId String?
  credential   Credential?        @relation(fields: [credentialId], references: [id])

  operation    FreshdeskOperation @default(CREATE_TICKET)
  variableName String             @default("freshdesk")

  // ── TICKET FIELDS ─────────────────────────────────────────
  subject      String             @default("") @db.Text
  description  String             @default("") @db.Text
  descriptionHtml String          @default("") @db.Text
  email        String             @default("") @db.Text
  name         String             @default("") @db.Text
  phone        String             @default("") @db.Text
  mobilePhone  String             @default("") @db.Text
  subject2     String             @default("") @db.Text
  ticketId     String             @default("") @db.Text

  // Priority: 1=Low, 2=Medium, 3=High, 4=Urgent
  priority     Int                @default(2)

  // Status: 2=Open, 3=Pending, 4=Resolved, 5=Closed
  status       Int                @default(2)

  // Source: 1=Email, 2=Portal, 3=Phone, 7=Chat, 9=Twitter DM, 10=WhatsApp
  source       Int                @default(2)

  // Type: Question, Incident, Problem, Feature Request, Refund Request, etc.
  ticketType   String             @default("")

  responderId  String             @default("") @db.Text
  groupId      String             @default("") @db.Text
  productId    String             @default("") @db.Text
  companyId    String             @default("") @db.Text
  fwdEmail     String             @default("") @db.Text

  // Tags — comma-separated list
  tags         String             @default("") @db.Text

  // Custom fields JSON — { "cf_order_id": "ORD-123" }
  customFields String             @default("{}") @db.Text

  // ── NOTE FIELDS ───────────────────────────────────────────
  noteId       String             @default("") @db.Text
  noteBody     String             @default("") @db.Text
  notePrivate  Boolean            @default(false)
  noteUserId   String             @default("") @db.Text

  // ── CONTACT FIELDS ────────────────────────────────────────
  contactId    String             @default("") @db.Text
  contactEmail String             @default("") @db.Text
  contactName  String             @default("") @db.Text
  contactPhone String             @default("") @db.Text
  contactMobile String            @default("") @db.Text
  contactJobTitle String          @default("") @db.Text
  contactTimeZone String          @default("") @db.Text
  contactLanguage String          @default("") @db.Text
  contactTags  String             @default("") @db.Text
  contactCompanyId String         @default("") @db.Text
  mergeTargetId String            @default("") @db.Text

  // ── COMPANY FIELDS ────────────────────────────────────────
  companyName  String             @default("") @db.Text
  companyDomain String            @default("") @db.Text
  companyDescription String       @default("") @db.Text
  companyNote  String             @default("") @db.Text

  // ── AGENT FIELDS ──────────────────────────────────────────
  agentId      String             @default("") @db.Text

  // ── REPLY FIELDS ──────────────────────────────────────────
  replyBody    String             @default("") @db.Text
  replyFrom    String             @default("") @db.Text
  replyTo      String             @default("") @db.Text
  replyCc      String             @default("") @db.Text
  replyBcc     String             @default("") @db.Text

  // ── SEARCH / FILTER FIELDS ────────────────────────────────
  searchQuery  String             @default("") @db.Text
  filterBy     String             @default("")
  orderBy      String             @default("created_at")
  orderType    String             @default("desc")
  page         Int                @default(1)
  perPage      Int                @default(30)
  updatedSince String             @default("") @db.Text
  includeStats Boolean            @default(false)

  continueOnFail Boolean          @default(false)

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  workflow     workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum MediaUploadSource {
  URL
  BASE64
  GOOGLE_DRIVE
}

model MediaUploadNode {
  id           String            @id @default(cuid())
  nodeId       String            @unique
  workflowId   String

  source       MediaUploadSource @default(URL)
  inputField   String            @default("")
  mimeTypeHint String            @default("image/png")
  filename     String            @default("")

  // For Google Drive source
  credentialId String?

  variableName   String  @default("media")
  continueOnFail Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model SortNode {
  id         String   @id @default(cuid())
  nodeId     String   @unique
  workflowId String

  // Operation mode
  // "SORT_ARRAY"     — sort array of objects or primitives
  // "SORT_KEYS"      — sort the keys of an object
  // "REVERSE"        — reverse array order
  // "SHUFFLE"        — random order (Fisher-Yates)
  operation  String   @default("SORT_ARRAY")

  // JSON-serialized array of SortKey objects:
  // [{ field: string, direction: "asc"|"desc", type: "auto"|"string"|
  //    "number"|"date"|"boolean", nulls: "first"|"last",
  //    caseSensitive: boolean, locale: string, natural: boolean }]
  sortKeys   String   @default("[]") @db.Text

  // Input path — dot-notation path to the array inside context
  // e.g. "googleSheets.rows" or "razorpayTrigger.payload.items"
  // Empty string = use the entire previous node output
  inputPath  String   @default("")

  // Variable name for output
  variableName String  @default("sort")

  // Whether to sort in-place (mutate) or return new array
  // Always false in executor — immutable by default
  // Kept for future UI hint
  inPlace    Boolean  @default(false)

  workflow   workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model FilterNode {
  id           String @id @default(cuid())
  nodeId       String @unique
  workflowId   String

  operation       String  @default("FILTER_ARRAY")
  inputArray      String  @default("") @db.Text
  inputObject     String  @default("") @db.Text
  conditionGroups String  @default("[]") @db.Text
  rootLogic       String  @default("AND")
  outputMode      String  @default("filtered")
  variableName    String  @default("filter")
  stopOnEmpty     Boolean @default(false)
  includeMetadata Boolean @default(false)
  continueOnFail  Boolean @default(false)

  // FILTER_OBJECT_KEYS specific:
  keyFilterMode   String  @default("key_name")
  keepMatching    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

enum CashfreeOperation {
  // ── ORDERS (Payment Gateway) ──────────────────────────────
  CREATE_ORDER
  GET_ORDER
  TERMINATE_ORDER
  PAY_ORDER

  // ── PAYMENTS ──────────────────────────────────────────────
  GET_PAYMENTS_FOR_ORDER
  GET_PAYMENT_BY_ID

  // ── REFUNDS ───────────────────────────────────────────────
  CREATE_REFUND
  GET_REFUND
  GET_ALL_REFUNDS_FOR_ORDER

  // ── SETTLEMENTS ───────────────────────────────────────────
  GET_SETTLEMENTS_FOR_ORDER
  GET_ALL_SETTLEMENTS
  GET_SETTLEMENT_RECON

  // ── PAYMENT LINKS ─────────────────────────────────────────
  CREATE_PAYMENT_LINK
  GET_PAYMENT_LINK
  CANCEL_PAYMENT_LINK
  GET_ORDERS_FOR_LINK

  // ── SUBSCRIPTIONS ─────────────────────────────────────────
  CREATE_SUBSCRIPTION_PLAN
  GET_SUBSCRIPTION_PLAN
  CREATE_SUBSCRIPTION
  GET_SUBSCRIPTION
  MANAGE_SUBSCRIPTION
  GET_SUBSCRIPTION_PAYMENTS

  // ── PAYOUTS ───────────────────────────────────────────────
  GET_PAYOUT_BALANCE
  ADD_BENEFICIARY
  GET_BENEFICIARY
  REMOVE_BENEFICIARY
  TRANSFER_TO_BENEFICIARY
  GET_TRANSFER_STATUS
  BULK_TRANSFER
  GET_BATCH_TRANSFER_STATUS

  // ── UPI ───────────────────────────────────────────────────
  VALIDATE_UPI_ID
  CREATE_UPI_PAYMENT_LINK

  // ── OFFERS ────────────────────────────────────────────────
  CREATE_OFFER
  GET_OFFER

  // ── WEBHOOKS ──────────────────────────────────────────────
  VERIFY_WEBHOOK_SIGNATURE
}

model CashfreeNode {
  id           String             @id @default(cuid())
  nodeId       String             @unique
  workflowId   String
  credentialId String?
  credential   Credential?        @relation(fields: [credentialId], references: [id])

  operation    CashfreeOperation  @default(CREATE_ORDER)
  variableName String             @default("cashfree")
  continueOnFail Boolean          @default(false)

  // ── ORDER FIELDS ──────────────────────────────────────────
  orderId           String         @default("") @db.Text
  orderAmount       String         @default("") @db.Text
  orderCurrency     String         @default("INR")
  orderNote         String         @default("") @db.Text
  orderMeta         String         @default("{}") @db.Text

  // ── CUSTOMER FIELDS ───────────────────────────────────────
  customerId        String         @default("") @db.Text
  customerEmail     String         @default("") @db.Text
  customerPhone     String         @default("") @db.Text
  customerName      String         @default("") @db.Text
  customerBankAccountNumber String  @default("") @db.Text
  customerBankIfsc  String         @default("") @db.Text
  customerBankCode  String         @default("")

  // ── PAYMENT FIELDS ────────────────────────────────────────
  cfPaymentId       String         @default("") @db.Text
  cfOrderId         String         @default("") @db.Text
  paymentMethod     String         @default("") @db.Text

  // ── REFUND FIELDS ─────────────────────────────────────────
  refundId          String         @default("") @db.Text
  refundAmount      String         @default("") @db.Text
  refundNote        String         @default("") @db.Text
  refundSpeed       String         @default("STANDARD")
  refundSplits      String         @default("[]") @db.Text

  // ── SETTLEMENT FIELDS ─────────────────────────────────────
  settlementId      String         @default("") @db.Text
  startDate         String         @default("") @db.Text
  endDate           String         @default("") @db.Text
  cursor            String         @default("")
  limit             Int            @default(10)

  // ── PAYMENT LINK FIELDS ───────────────────────────────────
  linkId            String         @default("") @db.Text
  linkAmount        String         @default("") @db.Text
  linkCurrency      String         @default("INR")
  linkPurpose       String         @default("") @db.Text
  linkDescription   String         @default("") @db.Text
  linkExpiryTime    String         @default("") @db.Text
  linkNotifyPhone   Boolean        @default(true)
  linkNotifyEmail   Boolean        @default(true)
  linkAutoReminders Boolean        @default(true)
  linkMinPartialAmount String      @default("") @db.Text
  linkMeta          String         @default("{}") @db.Text

  // ── SUBSCRIPTION FIELDS ───────────────────────────────────
  subscriptionId    String         @default("") @db.Text
  planId            String         @default("") @db.Text
  planName          String         @default("") @db.Text
  planType          String         @default("PERIODIC")
  planIntervalType  String         @default("MONTH")
  planIntervals     Int            @default(1)
  planMaxCycles     Int            @default(0)
  planMaxAmount     String         @default("") @db.Text
  subscriptionFirstChargeTime String @default("") @db.Text
  subscriptionExpiryTime String    @default("") @db.Text
  subscriptionReturnUrl String     @default("") @db.Text
  subscriptionNotifyUrl String     @default("") @db.Text
  subscriptionAction  String       @default("PAUSE")

  // ── PAYOUT FIELDS ─────────────────────────────────────────
  beneId            String         @default("") @db.Text
  beneName          String         @default("") @db.Text
  beneEmail         String         @default("") @db.Text
  benePhone         String         @default("") @db.Text
  beneBankAccount   String         @default("") @db.Text
  beneBankIfsc      String         @default("") @db.Text
  beneVpa           String         @default("") @db.Text
  beneAddress       String         @default("") @db.Text
  beneCity          String         @default("") @db.Text
  beneState         String         @default("India")
  benePincode       String         @default("") @db.Text

  transferId        String         @default("") @db.Text
  transferAmount    String         @default("") @db.Text
  transferRemarks   String         @default("") @db.Text
  transferMode      String         @default("banktransfer")
  batchTransferId   String         @default("") @db.Text
  batchEntries      String         @default("[]") @db.Text

  // ── UPI FIELDS ────────────────────────────────────────────
  upiVpa            String         @default("") @db.Text
  upiAmount         String         @default("") @db.Text
  upiDescription    String         @default("") @db.Text

  // ── OFFER FIELDS ──────────────────────────────────────────
  offerId           String         @default("") @db.Text
  offerMeta         String         @default("{}") @db.Text
  offerValidations  String         @default("{}") @db.Text
  offerDetails      String         @default("{}") @db.Text

  // ── WEBHOOK FIELDS ────────────────────────────────────────
  webhookSignature  String         @default("") @db.Text
  webhookTimestamp  String         @default("") @db.Text
  webhookRawBody    String         @default("") @db.Text
  webhookThrowOnFail Boolean       @default(true)

  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  workflow     workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([nodeId])
}

model AggregateNode {
  id           String @id @default(cuid())
  nodeId       String @unique
  workflowId   String

  // Primary operation
  operation    String @default("COUNT")

  // Dot-notation path to the input array
  inputPath    String @default("") @db.Text

  // Dot-notation field within each item to aggregate
  field        String @default("") @db.Text

  // For GROUP_BY: field to group items by
  groupByField String @default("")

  // For PIVOT: row field, column field, value field, value operation
  pivotRowField    String @default("")
  pivotColField    String @default("")
  pivotValueField  String @default("")
  pivotValueOp     String @default("SUM")

  // For CONCATENATE: separator string (default ", ")
  separator    String @default(", ")

  // For PERCENTILE: the percentile to compute (0–100)
  percentile   Float  @default(90)

  // For COUNT: optional filter condition (JSON FilterCondition[])
  countFilter  String @default("") @db.Text

  // For MULTI: JSON array of AggregateOperation objects
  multiOps     String @default("[]") @db.Text

  // For GROUP_BY with nested aggregation:
  groupAggOps  String @default("[]") @db.Text

  // Output options
  variableName    String  @default("aggregate")
  includeInput    Boolean @default(false)
  sortOutput      Boolean @default(true)
  topN            Int     @default(0)
  nullHandling    String  @default("exclude")
  roundDecimals   Int     @default(2)
  continueOnFail  Boolean @default(false)

  workflow workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([nodeId])
}

model PostgresNode {
  id           String @id @default(cuid())
  nodeId       String @unique
  workflowId   String

  // The operation to perform
  operation    String @default("EXECUTE_QUERY")

  // Credential reference
  credentialId String?

  // For visual query builder (SELECT, UPDATE, DELETE, COUNT, EXISTS, UPSERT):
  tableName    String @default("")    // target table
  schemaName   String @default("public")

  // SELECT options:
  // JSON array of column names to return. [] = SELECT *
  selectColumns  String @default("[]") @db.Text
  // JSON array of WhereCondition objects
  whereConditions String @default("[]") @db.Text
  // JSON array of OrderBy objects: [{ column, direction }]
  orderBy        String @default("[]") @db.Text
  // LIMIT rows. 0 = no limit
  limitRows      Int    @default(0)
  // OFFSET for pagination
  offsetRows     Int    @default(0)
  // JOIN configuration: JSON array of JoinClause objects
  joins          String @default("[]") @db.Text

  // INSERT / UPSERT:
  // JSON object or template string that resolves to row data
  insertData     String @default("") @db.Text
  // For UPSERT: column(s) to check for conflict
  conflictColumns String @default("[]") @db.Text
  // For UPSERT: columns to update on conflict. [] = all non-conflict columns
  updateOnConflict String @default("[]") @db.Text

  // UPDATE:
  // JSON object of { column: newValue } — supports template expressions
  updateData     String @default("") @db.Text

  // INSERT_MANY:
  // Template path to array of row objects: "{{filter.items}}"
  insertManyPath String @default("") @db.Text
  // Column names to insert. [] = infer from first row
  insertManyColumns String @default("[]") @db.Text

  // EXECUTE_QUERY:
  // Raw SQL with $1, $2... placeholders
  query          String @default("") @db.Text
  // JSON array of query parameters [value1, value2...]
  queryParams    String @default("[]") @db.Text

  // EXECUTE_TRANSACTION:
  // JSON array of { query, params } objects — run atomically
  transactionStatements String @default("[]") @db.Text

  // EXECUTE_FUNCTION:
  functionName   String @default("")
  functionArgs   String @default("[]") @db.Text  // JSON array

  // FULL_TEXT_SEARCH:
  searchColumn   String @default("")
  searchQuery    String @default("")
  searchLanguage String @default("english")  // pg language: "simple", "english", etc.
  searchLimit    Int    @default(10)

  // JSON_PATH_QUERY:
  jsonColumn     String @default("")
  jsonPath       String @default("")  // e.g. '$.payment.amount'

  // JSON_SET_FIELD:
  jsonSetColumn  String @default("")
  jsonSetPath    String @default("")  // e.g. '{payment,status}'
  jsonSetValue   String @default("")  // new value (supports template)

  // CREATE_TABLE:
  // JSON array of ColumnDefinition objects
  columnDefinitions String @default("[]") @db.Text
  createTableIfNotExists Boolean @default(true)

  // Output options
  variableName    String  @default("postgres")
  returnData      Boolean @default(true)   // whether to return affected rows
  continueOnFail  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow   workflow   @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  credential Credential? @relation(fields: [credentialId], references: [id], onDelete: SetNull)

  @@index([workflowId])
  @@index([nodeId])
  @@index([credentialId])
}
