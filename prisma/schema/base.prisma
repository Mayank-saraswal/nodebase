// ─────────────────────────────────────────────────────────────
// Nodebase — Prisma Schema: Base Configuration
// Generator and datasource definitions
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  output          = "../../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}
