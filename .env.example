Local PostgreSQL database (Docker)
DATABASE_URL='postgresql://workflow_user:workflow_password@localhost:5432/workflow_db'

# Direct database URL for Prisma migrations (bypasses connection pooler).
# In local dev, this can be the same as DATABASE_URL.
# In production with a pooler (Supabase/Neon/PgBouncer), set this to
# the direct (non-pooled) connection string so migrations work correctly.
DIRECT_DATABASE_URL='postgresql://workflow_user:workflow_password@localhost:5432/workflow_db'

